{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/node_app.js"
    },
    {
      "source": "/api/stocks/(.*)",
      "destination": "/api/node_app.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/python_app.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
